8b?auto=format&fit=crop&w=1600&q=80","width":6000,"height":4000,"camera":{"make":"Canon","model":"EOS R5","lens":"RF 24-105mm F4 L IS USM"},"exif":{"aperture":"f/5.6","shutterSpeed":"1/60s","iso":200,"focalLength":70,"focalLength35mm":70,"dateTaken":"2024-10-02T07:45:00Z","exposureProgram":"Aperture Priority","meteringMode":"Pattern"},"location":{"name":"Black Forest, Germany","latitude":48.0125,"longitude":8.2144},"albums":["landscape-escapes","minimalist-moments"],"tags":["forest","mist","green","minimalism","nature"],"aspectRatio":1.5},{"id":"tokyo-crosswalk","title":"Midday Crossroads","description":"High-angle view of Shibuya Crossing. Pedestrians scramble in all directions, captured in sharp geometric patterns under the harsh midday sun.","r2Url":"https://images.unsplash.com/photo-1540959733332-eab4deceeaf7?auto=format&fit=crop&w=1600&q=80","width":6000,"height":4000,"camera":{"make":"Fujifilm","model":"X-T5","lens":"XF 18-55mm F2.8-4 R LM OIS"},"exif":{"aperture":"f/8.0","shutterSpeed":"1/250s","iso":160,"focalLength":18,"focalLength35mm":27,"dateTaken":"2024-11-06T12:05:14Z","exposureProgram":"Aperture Priority","meteringMode":"Multi-segment"},"location":{"name":"Shibuya, Tokyo, Japan","latitude":35.6595,"longitude":139.7005},"albums":["urban-exploration"],"tags":["tokyo","street","cityscape","geometry","japan"],"aspectRatio":1.5}]}